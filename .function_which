# ------------------------------
#  Color Variables
# ------------------------------

C_NC="\e[0m"
C_RD="\e[31m"
C_GN="\e[32m"
C_YW="\e[33m"


##  Remove current which as alias so function below works
if [[ $(type -t which) = "alias"  ]]; then
  unalias which
fi


# ------------------------------
#  [Function which]  #
#   - Finds the location of a function, alias, builtin, etc
# ------------------------------

which() {
## Written by Adam Brandeis - 2019-11-11
    local opts=()
    local silent=0
    local OPTIND opt

    # ---------- option parsing ----------
    while getopts ":as-:" opt; do
        case "$opt" in
            a)
                opts+=("-a")
                ;;
            s)
                opts+=("-s")
                silent=1
                ;;
            -)
                case "$OPTARG" in
                    help)
                        echo
                        echo -e "${C_CY}which${C_NC} — enhanced bash function"
                        echo
                        echo "Usage: which [options] <command>"
                        echo
                        echo "Options:"
                        echo "  -a            show all matches"
                        echo "  -s            silent (status only)"
                        echo "  --help        display this help"
                        echo "  --version     display version"
                        echo
                        return 0
                        ;;
                    version)
                        echo "which (enhanced bash function) 1.0.0"
                        command which --version 2>/dev/null | head -n 1
                        return 0
                        ;;
                    *)
                        echo "which: invalid option --$OPTARG"
                        return 2
                        ;;
                esac
                ;;
            *)
                echo "which: invalid option"
                return 2
                ;;
        esac
    done
    shift $((OPTIND-1))

    [[ $# -eq 0 ]] && {
        echo "which: missing operand"
        return 2
    }

    # --- run builtin which, but NEVER exit early ---
    builtin_rc=0
    command which "${opts[@]}" "$@" 2>/dev/null || builtin_rc=$?

    # silent mode honours builtin which only
    (( silent )) && return $builtin_rc

    # --- now ALWAYS run enhanced logic ---
    for cmd in "$@"; do
        echo
        if [[ $(type -t "$cmd") =~ ^(alias|function|builtin|file|keyword)$ ]]; then
            echo -e "${C_GN}$cmd is a          :${C_YW} $(type -t "$cmd") ${C_NC}"

            case "$(type -t "$cmd")" in
                alias)
                    type -a "$cmd"
                    echo
                    echo -e "${C_GN}$cmd is located in :${C_YW}${C_NC}"

                    grep -Rn --color=always \
                        -E "^[[:space:]]*alias[[:space:]]+$cmd=" \
                        ${BASHRC_HOME} ~/.*bash* ~/.profile \
                        /etc/{bash.bashrc,bashrc,profile,profile.d} \
                        2>/dev/null \
                    | grep -v '\.bak$' \
                    | grep -v "${HOME}/.bash_history"
                    ;;
                function)
                    shopt -s extdebug
                    echo -e "${C_GN}$cmd is located in :${C_YW} $(declare -F "$cmd") ${C_NC}"
                    shopt -u extdebug
                    type -a "$cmd"
                    ;;
                *)
                    type -a "$cmd"
                  man -f "$cmd" 2>/dev/null
                    ;;
            esac
        else
            echo -e "${C_RD}$cmd not found or not a valid command${C_NC}"
        fi
    done

    return $builtin_rc

}      ##### FUNCTION END : which


# ------------------------------
#  [Helper which ] 
#    - adds autocomplete to which function
# ------------------------------

_which_complete()
{
    local cur prev
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"

    # Long / short options
    if [[ "$cur" == -* ]]; then
        COMPREPLY=( $(compgen -W "-a -s --help --version" -- "$cur") )
        return 0
    fi

    # Command-like entities
    COMPREPLY+=( $(compgen -A alias -- "$cur") )
    COMPREPLY+=( $(compgen -A function -- "$cur") )
    COMPREPLY+=( $(compgen -A builtin -- "$cur") )
    COMPREPLY+=( $(compgen -A keyword -- "$cur") )
    COMPREPLY+=( $(compgen -A file -- "$cur") )
}

complete -F _which_complete which
