    "8": "ExecutionReport",
    "D": "NewOrderSingle",
    "F": "OrderCancelRequest",
    "W": "MarketDataSnapshotFullRefresh",
    "X": "MarketDataIncrementalRefresh",
}

ENUMS = {
    35: MSGTYPE_ENUM,
    269: {
