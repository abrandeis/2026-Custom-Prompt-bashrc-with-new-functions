# Author:    Adam Brandeis
# Filename:  fixutil (for fixlog and fixfmt functions)
# Created:   2026-03-17
# Purpose:   Stream-friendly FIX log formatter and filter.
#            - Provides two user-facing commands:
#              * fixlog → fast inline FIX log viewing with delimiter replacement
#              * fixfmt → decoded, colorized, and pretty-formatted FIX output
#            - Normalizes FIX SOH delimiters (real SOH, ^A, \x01, \001)
#            - Strips upstream ANSI escape sequences (e.g., from grep --color)
#            - Designed for use with grep, cat, head, tail, tail -f, and less
#            - Reads from STDIN by default; accepts files as arguments
#
#            - add fixfmt soft link 
#                ln -s fixutil fixfmt
# Layouts:
#   ${SFX_INSTALL_PATH}/data/LT/logs/<session>/logs/
#   ${SFX_INSTALL_PATH}/data/LP/logs/<session>/logs/
# ============================================

import sys
import os
import re
import argparse

# ---------- Mode detection ----------
def detect_mode():
    """Detect invoked mode robustly by inspecting argv[0]."""
    name = os.path.basename(sys.argv[0]).lower()
    if 'fixfmt' in name:
        return 'fixfmt'
    if 'fixlog' in name:
        return 'fixlog'
    return 'fixlog'  # conservative default
MODE = detect_mode()

# ---------- ANSI helpers ----------
class Ansi:
    RESET = '\x1b[0m'
    BOLD = '\x1b[1m'
    DIM = '\x1b[2m'
    RED = '\x1b[31m'
    GREEN = '\x1b[32m'
    YELLOW = '\x1b[33m'
    BLUE = '\x1b[34m'
    MAGENTA = '\x1b[35m'
    CYAN = '\x1b[36m'
    GRAY = '\x1b[90m'

ANSI_RE = re.compile(r'\x1b\[[0-9;]*m')
def strip_ansi(s: str) -> str:
    return ANSI_RE.sub('', s)

# ---------- FIX dictionaries (extend as needed) ----------
TAG_NAMES = {
    8: "BeginString",
    9: "BodyLength",
    10: "CheckSum",
    34: "MsgSeqNum",
    35: "MsgType",
    49: "SenderCompID",
    52: "SendingTime",
    56: "TargetCompID",
    98: "EncryptMethod",
    108: "HeartBtInt",
    141: "ResetSeqNumFlag",
    262: "MDReqID",
    268: "NoMDEntries",
    269: "MDEntryType",
    270: "MDEntryPx",
    271: "MDEntrySize",
    299: "QuoteEntryID",
    55: "Symbol",
    167: "SecurityType",
}

MSGTYPE_ENUM = {
    "0": "Heartbeat",
    "1": "TestRequest",
    "2": "ResendRequest",
    "3": "Reject",
    "4": "SequenceReset",
    "5": "Logout",
